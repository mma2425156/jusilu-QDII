# 🚀 QDII 基金监控系统 - 环境变量模板
# 复制此文件为 .env 并填写实际值

# ========================
# 🌐 jisilu.cn 登录（溢价率数据需要登录才能查看）
# ========================
JISILU_USERNAME=your_jisilu_username
JISILU_PASSWORD=your_jisilu_password

# ========================
# 📧 邮件 SMTP 设置
# ========================
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_password
MAIL_SENDER=your_email@example.com
MAIL_SENDER_NAME=QDII基金监控系统
SMTP_USE_SSL=true

# ========================
# 💬 多渠道通知设置
# （可选填写，任选渠道使用）
# ========================

# 钉钉机器人（机器人设置 → 添加机器人 → 加签模式）
DINGTALK_TOKEN=your_dingtalk_robot_token
DINGTALK_SECRET=your_dingtalk_secret

# 飞书机器人
FEISHU_TOKEN=your_feishu_robot_token
FEISHU_SECRET=your_feishu_secret

# 企业微信（应用消息 → 企业 ID / 应用 ID / Secret）
WECOM_CORP_ID=your_corp_id
WECOM_AGENT_ID=your_agent_id
WECOM_CORP_SECRET=your_corp_secret

# Telegram Bot
TELEGRAM_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# PushPlus（微信推送，http://www.pushplus.plus）
PUSHPLUS_TOKEN=your_pushplus_token

# Server酱（微信推送，https://sct.ftqq.com）
# Turbo 版：SCT 开头；旧版：SCU 开头
SERVERCHAN_SCKEY=your_sckey

# Bark（iOS 推送，可填完整 URL 或 key）
BARK_KEY=your_bark_key

# iGot 推送
IGOT_KEY=your_igot_key

# 自定义 Webhook（POST JSON 到此 URL）
CUSTOM_WEBHOOK=https://your-webhook-url.com/notify

# ========================
# 📊 数据筛选设置
# ========================
PREMIUM_THRESHOLD=5.0
DEFAULT_STATUS_FILTER=all
REFRESH_COOLDOWN=30
SNAPSHOT_KEEP_DAYS=30

# ========================
# 🗄️ 数据库配置
# ========================
DATABASE_URL=sqlite:///instance/app.db

# ========================
# 🌐 Web 服务设置
# ========================
FLASK_PORT=8866
FLASK_HOST=0.0.0.0
FLASK_DEBUG=false
SECRET_KEY=change_this_to_a_random_string

# ========================
# 🗂️ 文件路径（相对项目根目录）
# ========================
DATA_DIR=qdii_tables
OUTPUT_CLEAN=qdii_all_clean.csv
OUTPUT_FILTERED=qdii_filtered.csv

# ========================
# 🐛 日志配置
# ========================
LOG_LEVEL=INFO
LOG_FILE=logs/qdii.log
